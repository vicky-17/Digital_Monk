<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ════════════════════════════════════════════════════════════════════
         PERMISSIONS
         ════════════════════════════════════════════════════════════════════ -->

    <!-- ── 1. Network ────────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- ── 2. Boot ───────────────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- ── 3. Foreground Services ────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- ── 4. Notifications (Android 13+) ───────────────────────────────── -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- ── 5. Special Access (granted via system Settings) ──────────────── -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission
        android:name="android.permission.BIND_VPN_SERVICE"
        tools:ignore="ProtectedPermissions" />

    <!-- ── 6. Alarms & Wake ──────────────────────────────────────────────── -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- ── 7. Battery / Persistence ─────────────────────────────────────── -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- ── 8. App Inspection ─────────────────────────────────────────────── -->
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />


    <!-- ════════════════════════════════════════════════════════════════════
         APPLICATION
         ════════════════════════════════════════════════════════════════════ -->

    <application
        android:name=".DigitalMonkApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DigitalMonk"
        android:networkSecurityConfig="@xml/network_security_config">


        <!-- ════════════════════════════════════════════════════════════════
             ACTIVITIES
             ════════════════════════════════════════════════════════════════ -->

        <!-- ── Main Entry Point ──────────────────────────────────────────── -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ── Onboarding / Setup ─────────────────────────────────────────── -->
        <activity
            android:name=".ui.onboarding.PermissionSetupActivity"
            android:exported="false" />

        <activity
            android:name=".ui.auth.PinSetupActivity"
            android:exported="false" />

        <!-- ── App Blocking UI ───────────────────────────────────────────── -->
        <!--
             GuardianRedirectActivity: no UI chrome, instant launch.
             BlockedPageActivity: full-screen block page shown to child.
             Both share block_task affinity so they form an isolated back stack.
        -->
        <activity
            android:name=".service.accessibility.GuardianRedirectActivity"
            android:exported="false"
            android:excludeFromRecents="false"
            android:launchMode="singleInstance"
            android:noHistory="true"
            android:taskAffinity="com.example.digitalmonk.block_task"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen" />

        <activity
            android:name=".ui.block.BlockedPageActivity"
            android:exported="false"
            android:excludeFromRecents="false"
            android:launchMode="singleInstance"
            android:noHistory="true"
            android:taskAffinity="com.example.digitalmonk.block_task"
            android:theme="@style/Theme.DigitalMonk" />


        <!-- ════════════════════════════════════════════════════════════════
             SERVICES
             ════════════════════════════════════════════════════════════════ -->

        <!-- ── Accessibility Service ─────────────────────────────────────── -->
        <service
            android:name=".service.accessibility.GuardianAccessibilityService"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_config" />
        </service>

        <!-- ── Watchdog Service (foreground, survives recents swipe) ─────── -->
        <!--
             stopWithTask="false": keeps running after user swipes app from recents.
        -->
        <service
            android:name=".service.WatchdogService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:stopWithTask="false">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="parental_control_guardian" />
        </service>

        <!-- ── Watchdog Job Service (JobScheduler backup) ────────────────── -->
        <!--
             exported="true" + BIND_JOB_SERVICE: required so the OS scheduler
             can bind to it. The permission ensures only the system can call it.
        -->
        <service
            android:name=".service.WatchdogJobService"
            android:exported="true"
            android:permission="android.permission.BIND_JOB_SERVICE" />

        <!-- ── VPN Service (DNS-based content filter) ────────────────────── -->
        <service
            android:name=".service.vpn.DnsVpnService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:permission="android.permission.BIND_VPN_SERVICE">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
            <meta-data
                android:name="android.net.VpnService"
                android:value="@string/vpn_service_description" />
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="dns_filter_for_parental_control" />
        </service>

        <!-- ── VPN Monitor Service (Layer-3 keep-alive companion) ────────── -->
        <!--
             Bound service that runs alongside DnsVpnService.
             When the OEM kills the VPN process, onDestroy() fires here,
             reads the last heartbeat, and restarts DnsVpnService if it was
             killed unexpectedly (not stopped cleanly by the user).
        -->
        <service
            android:name=".service.vpn.VpnMonitorService"
            android:exported="false" />

        <!-- ── Overlay Services ──────────────────────────────────────────── -->
        <!--
             OverlayService       : general-purpose parental control overlay.
             GuardianOverlayService: accessibility health-check guide bubble.
             SettingsBlockOverlayService: blocks Settings pages to prevent
                                          uninstall / device-admin removal.
        -->
        <service
            android:name=".service.overlay.OverlayService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="overlay_for_parental_control" />
        </service>

        <service
            android:name=".service.overlay.GuardianOverlayService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="accessibility_guardian_overlay" />
        </service>

        <service
            android:name=".service.overlay.SettingsBlockOverlayService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="settings_page_block_overlay" />
        </service>


        <!-- ════════════════════════════════════════════════════════════════
             RECEIVERS
             ════════════════════════════════════════════════════════════════ -->

        <!-- ── Device Admin (anti-uninstall protection) ──────────────────── -->
        <receiver
            android:name=".receiver.MonkDeviceAdminReceiver"
            android:exported="true"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

        <!-- ── Boot Receiver ─────────────────────────────────────────────── -->
        <!--
             directBootAware="true": fires before the user unlocks after reboot.
             priority="1000"       : fires before other apps' boot receivers.
             Handles both standard and OEM-specific (HTC/Xiaomi) boot actions.
        -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:directBootAware="true"
            android:enabled="true"
            android:exported="true">
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <!-- ── Alarm Restart Receiver ────────────────────────────────────── -->
        <!--
             AlarmManager-based service resurrection backup.
             directBootAware="true": can fire before first unlock post-reboot.
        -->
        <receiver
            android:name=".receiver.AlarmRestartReceiver"
            android:directBootAware="true"
            android:exported="false">
            <intent-filter>
                <action android:name="com.example.digitalmonk.ALARM_RESTART" />
            </intent-filter>
        </receiver>

        <!-- ── Package Change Receiver ───────────────────────────────────── -->
        <receiver
            android:name=".receiver.PackageChangeReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.PACKAGE_ADDED" />
                <action android:name="android.intent.action.PACKAGE_REMOVED" />
                <data android:scheme="package" />
            </intent-filter>
        </receiver>

        <!-- ── App Update Receiver ───────────────────────────────────────── -->
        <!--
             Fires after our own APK is updated (Play Store or ADB install).
             All running services are killed on update — this receiver restarts
             DnsVpnService and re-schedules the watchdog if VPN filter was active.
             exported="false": MY_PACKAGE_REPLACED is only sent to our own app.
        -->
        <receiver
            android:name=".receiver.AppUpdateReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>


    </application>

</manifest>