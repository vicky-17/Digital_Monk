    <string-array name="guardian_steps_frozen">
        <item>1️⃣  Tap \'Open Accessibility Settings\' below</item>
        <item>2️⃣  Tap on \'Downloaded Apps\' below</item>
        <item>3️⃣  Find \'Digital Monk\' in the list</item>
        <item>4️⃣  Tap it and toggle the switch OFF</item>
        <item>5️⃣  Wait 2 seconds, then toggle it ON again</item>
        <item>6️⃣  Return here — the block will auto-lift</item>
    </string-array>

    <string-array name="guardian_steps_missing">
        <item>1️⃣  Tap \'Grant Permission\' below</item>
        <item>2️⃣  Tap on \'Downloaded Apps\' below</item>
        <item>3️⃣  Find \'Digital Monk\' in the list</item>
        <item>4️⃣  Tap \'Use Digital Monk\'</item>
        <item>5️⃣  Tap \'Allow\' on the confirmation dialog</item>
        <item>6️⃣  Return here — protection activates instantly</item>
    </string-array>

